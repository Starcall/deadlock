# Deadlock WPA Analytics — Environment Configuration

# SQLite database file path
DB_PATH=./deadlock.db

# Server port for the Go REST API
SERVER_PORT=8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# deadlock-api.com rate limiting (requests per second)
API_RATE_LIMIT=8

# Ingestion settings
INGEST_MATCH_COUNT=1000
INGEST_MIN_DURATION=900

# Model training settings
MODEL_SNAPSHOT_INTERVAL=300
MODEL_TEST_SPLIT=0.2
MODEL_L2_LAMBDA=1.0

# WPA computation settings
WPA_MIN_SAMPLE_SIZE=30

# Docker deployment — set these for your Proxmox host
# PUBLIC_API_URL=http://your-server-ip:8080
# PUBLIC_FRONTEND_URL=http://your-server-ip:3000
